{
  "name": "@camden-lowrance/flow",
  "version": "0.1.5",
  "type": "module",
  "description": "Workflow state for coding agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camden-lowrance/flow.git"
  },
  "homepage": "https://github.com/camden-lowrance/flow#readme",
  "bugs": {
    "url": "https://github.com/camden-lowrance/flow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "flow": "bin/flow",
    "flow-dashboard": "bin/flow-dashboard"
  },
  "exports": {
    ".": {
      "types": "./dist/bin/src/index.d.ts",
      "default": "./dist/bin/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "bin",
    "docs",
    "examples",
    "extensions",
    "desktop",
    "prompts",
    "skills",
    "dist/bin/src",
    "dist/dashboard",
    "dist/desktop",
    "dist/desktop-renderer",
    "src",
    "vite.desktop.config.ts",
    "vite.dashboard.config.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "check": "npm run check:cli-contract && npm run check:dashboard-readonly && tsc -p tsconfig.json --noEmit",
    "check:dashboard-readonly": "node scripts/check-dashboard-readonly.mjs",
    "check:cli-contract": "node scripts/check-flow-cli-contract.mjs",
    "test": "npm run check:cli-contract && npm run check:dashboard-readonly && npm run test:fast --",
    "test:fast": "node --import tsx scripts/test-flow.mjs",
    "test:core": "npm run test:fast -- test/flow.test.ts",
    "test:autoflow": "npm run test:fast -- test/autoflow-runner.test.ts",
    "test:dashboard": "npm run test:fast -- test/dashboard-state.test.ts",
    "test:sql": "npm run test:fast -- test/sql-state.test.ts test/sql-store.test.ts",
    "test:coverage": "node scripts/test-coverage.mjs",
    "build:flow": "tsc -p tsconfig.json",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "build": "npm run build:flow && npm run build:dashboard",
    "prepare": "husky",
    "prepack": "npm run build",
    "smoke:flow": "node scripts/smoke-flow.mjs",
    "smoke:dashboard": "node scripts/smoke-dashboard.mjs",
    "smoke:desktop": "node scripts/smoke-desktop.mjs",
    "readiness:public": "node scripts/public-readiness.mjs",
    "start": "node bin/flow",
    "start:all": "node scripts/start-all.mjs",
    "start:all:watch": "node --watch --watch-path=src scripts/start-all.mjs",
    "flow": "bin/flow",
    "dashboard": "bin/flow-dashboard",
    "autoflow": "node scripts/autoflow-issue.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "build:desktop:renderer": "vite build --config vite.desktop.config.ts",
    "build:desktop": "npm run build:desktop:renderer && node scripts/build-desktop.mjs",
    "start:desktop": "electron dist/desktop/main.js",
    "package:desktop:win": "npm run build && npm run build:desktop && electron-builder --win nsis --config desktop/electron-builder.yml",
    "package:desktop:mac": "npm run build && npm run build:desktop && electron-builder --mac --config desktop/electron-builder.yml",
    "package:desktop:linux": "npm run build && npm run build:desktop && electron-builder --linux AppImage --config desktop/electron-builder.yml"
  },
  "keywords": [
    "flow",
    "workflow",
    "coordination"
  ],
  "pi": {
    "extensions": [
      "./extensions/flow.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.11",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@hatchet-dev/typescript-sdk": "^1.23.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "express": "^5.2.1",
    "kysely": "^0.29.2",
    "lucide-react": "^1.17.0",
    "pathe": "^2.0.3",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typebox": "^1.1.39",
    "vite": "^8.0.14",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
