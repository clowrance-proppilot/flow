{
  "name": "flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Flow durable coordination and workflow orchestration engine.",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/test-flow.mjs",
    "build:flow": "tsc -p tsconfig.json",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "build": "npm run build:flow && npm run build:dashboard",
    "smoke:flow": "node scripts/smoke-flow.mjs",
    "smoke:dashboard": "node scripts/smoke-dashboard.mjs",
    "start": "node bin/flow",
    "start:all": "node scripts/start-all.mjs",
    "start:all:watch": "node --watch --watch-path=src scripts/start-all.mjs",
    "flow": "bin/flow",
    "dashboard": "bin/flow-dashboard",
    "autoflow": "node scripts/autoflow-issue.mjs"
  },
  "keywords": [
    "flow",
    "workflow",
    "coordination"
  ],
  "pi": {
    "extensions": [
      "./extensions/flow.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.19",
    "typebox": "^1.1.38",
    "vite": "^7.3.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
